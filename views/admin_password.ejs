<%- include('partials/header') %>

<div class="card login-card">
    <div class="page-header-row">
        <h1 class="page-title">Смена пароля</h1>
        <a href="/admin" class="btn btn-ghost">← К панели</a>
    </div>

    <p class="hint">
        Минимальная длина нового пароля — 6 символов. После сохранения
        используйте новый пароль при следующем входе.
    </p>

    <form action="/admin/password" method="POST" class="form" autocomplete="off">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <label class="form-label">
            Текущий пароль
            <input type="password" name="current" class="form-input" required>
        </label>
        <label class="form-label">
            Новый пароль
            <input type="password" name="next" class="form-input" required minlength="6">
        </label>
        <label class="form-label">
            Подтверждение нового пароля
            <input type="password" name="confirm" class="form-input" required minlength="6">
        </label>
        <button type="submit" class="btn btn-primary btn-lg">Сохранить</button>
    </form>
</div>

<%- include('partials/footer') %>
