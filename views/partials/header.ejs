<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — ADOR МРК</title>
    <link rel="stylesheet" href="/css/style.css?v=1.3">
</head>
<body>
    <header class="site-header">
        <div class="container header-inner">
            <div class="brand">
                <strong>ADOR</strong>
                <span class="brand-sub">«Подростки о родителях»</span>
            </div>
            <nav class="nav">
                <% if (typeof user !== 'undefined' && user) { %>
                    <span class="nav-info">
                        <%= user.last_name %> <%= user.first_name.charAt(0) %>. (гр. <%= user.group_name %>)
                    </span>
                    <form action="/logout" method="POST" class="logout-form">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button type="submit" class="btn btn-ghost btn-sm">Выйти</button>
                    </form>
                <% } else if (typeof admin !== 'undefined' && admin) { %>
                    <span class="nav-info">Админ: <%= admin.full_name %></span>
                    <a href="/admin" class="btn btn-ghost btn-sm">Панель</a>
                    <form action="/admin/logout" method="POST" class="logout-form">
                        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                        <button type="submit" class="btn btn-ghost btn-sm">Выход</button>
                    </form>
                <% } else { %>
                    <a href="/admin/login" class="nav-link">Вход для администратора</a>
                <% } %>
            </nav>
        </div>
    </header>

    <main class="container main-content">
        <% if (typeof errorMessages !== 'undefined' && errorMessages.length > 0) { %>
            <% errorMessages.forEach(function(msg) { %>
                <div class="alert alert-error"><%= msg %></div>
            <% }); %>
        <% } %>
        <% if (typeof successMessages !== 'undefined' && successMessages.length > 0) { %>
            <% successMessages.forEach(function(msg) { %>
                <div class="alert alert-success"><%= msg %></div>
            <% }); %>
        <% } %>
