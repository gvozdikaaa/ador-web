<%- include('partials/header') %>

<div class="card">
    <div class="page-header-row">
        <h1 class="page-title">Панель администратора</h1>
        <div class="page-actions">
            <a href="/admin/settings"  class="btn btn-secondary">Настройки системы</a>
            <a href="/admin/questions" class="btn btn-secondary">Управление утверждениями</a>
            <a href="/admin/password"  class="btn btn-secondary">Сменить пароль</a>
        </div>
    </div>

    <p class="hint">Последние 100 записей пользователей, прошедших тестирование.</p>

    <% if (users.length === 0) { %>
        <div class="empty-state">
            <p>Пока нет пройденных тестов.</p>
        </div>
    <% } else { %>
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Фамилия и имя</th>
                    <th>Группа</th>
                    <th>Возраст</th>
                    <th>Пол</th>
                    <th>Сессий</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(function(u) { %>
                    <tr>
                        <td><%= u.id %></td>
                        <td><%= u.last_name %> <%= u.first_name %></td>
                        <td><%= u.group_name %></td>
                        <td><%= u.age %></td>
                        <td><%= u.gender === 'male' ? 'м' : 'ж' %></td>
                        <td><%= u.sessions_count %></td>
                        <td><%= new Date(u.created_at).toLocaleString('ru-RU') %></td>
                        <td class="actions-cell">
                            <a href="/admin/users/<%= u.id %>" class="btn btn-ghost btn-sm">Открыть</a>
                            <form action="/admin/users/<%= u.id %>/delete" method="POST"
                                  class="inline-form"
                                  onsubmit="return confirm('Удалить запись пользователя и все его результаты?');">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                            </form>
                        </td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } %>
</div>

<%- include('partials/footer') %>
