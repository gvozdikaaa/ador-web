<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> — ADOR МРК</title>
    <link rel="stylesheet" href="/css/style.css?v=1.3">
</head>
<body class="admin-login-body">
    <div class="admin-login-wrap">
        <div class="card login-card">
            <h1 class="page-title">Вход для администратора</h1>
            <p class="hint">
                Доступ к управлению системой ADOR. Используйте служебные
                учётные данные.
            </p>

            <% if (typeof errorMessages !== 'undefined' && errorMessages.length > 0) { %>
                <% errorMessages.forEach(function(msg) { %>
                    <div class="alert alert-error"><%= msg %></div>
                <% }); %>
            <% } %>
            <% if (typeof successMessages !== 'undefined' && successMessages.length > 0) { %>
                <% successMessages.forEach(function(msg) { %>
                    <div class="alert alert-success"><%= msg %></div>
                <% }); %>
            <% } %>

            <form action="/admin/login" method="POST" class="form" autocomplete="off">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <label class="form-label">
                    Логин
                    <input type="text" name="login" class="form-input" required>
                </label>
                <label class="form-label">
                    Пароль
                    <input type="password" name="password" class="form-input" required>
                </label>
                <button type="submit" class="btn btn-primary btn-lg">Войти</button>
            </form>

            <p class="back-link">
                <a href="/">← Вернуться к странице тестирования</a>
            </p>
        </div>
    </div>
</body>
</html>
